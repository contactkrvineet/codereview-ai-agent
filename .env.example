# Copy this to .env for local development.
# In production (Render/Railway/Fly), set these in the platform dashboard instead.

# REQUIRED — get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OPTIONAL — raises GitHub unauthenticated rate limit (60/hr) to authenticated (5000/hr)
# Create a token at https://github.com/settings/tokens (no scopes needed for public repos)
# GITHUB_TOKEN=ghp_your_token_here

# Defaults — uncomment to override
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-2.0-flash
# RATE_LIMIT_PER_HOUR=10
# RATE_LIMIT_PER_DAY=50
# MAX_DIFF_BYTES=200000
# MAX_FILES_PER_REVIEW=20
